# ── Database ─────────────────────────────────────────────
# PostgreSQL connection string (connection_limit recommended: 5 for small servers)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DB_NAME?connection_limit=5"

# ── NextAuth ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-secure-random-string"
# Public URL of the app (must match actual domain)
NEXTAUTH_URL="https://yourdomain.com"

# ── Admin seed ────────────────────────────────────────────
# Used only by: npm run seed
SEED_ADMIN_EMAIL="admin@yourdomain.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Amministratore"

# ── Super Admin ───────────────────────────────────────────
# Used only by: npm run create-superadmin
SA_EMAIL="superadmin@yourdomain.com"
SA_PASSWORD="ChangeMe456!"

# ── Optional: update check ────────────────────────────────
# GitHub repo in "owner/repo" format for version check (leave empty to disable)
# GITHUB_REPO="your-org/restaurant-booking"
